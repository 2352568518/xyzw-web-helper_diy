# 本地 PostgreSQL 数据库配置
# 复制此文件为 .env.local 并填入实际值

# ==================== 数据库配置 ====================
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/xyzw_helper

# 或者分开配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xyzw_helper
DB_USER=postgres
DB_PASSWORD=your_password

# ==================== 服务配置 ====================
PORT=3001
NODE_ENV=production

# ==================== 安全配置 ====================
# JWT 密钥 (用于生成和验证 JWT Token)
# 可以使用 openssl rand -hex 32 生成
JWT_SECRET=your-random-jwt-secret-key

# ==================== 可选配置 ====================
# 日志级别: error | warn | info | debug
LOG_LEVEL=info

# 请求速率限制 (每分钟最大请求数)
RATE_LIMIT_MAX=100

# CORS 允许的源 (多个用逗号分隔)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
