[Unit]
Description=XYZW Web Helper Backend
Documentation=https://github.com/your-username/xyzw_web_helper_diy
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/xyzw-web-helper/backend
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=10
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=xyzw-backend

# 环境变量
EnvironmentFile=/opt/xyzw-web-helper/backend/.env

# 资源限制
LimitNOFILE=65536
MemoryMax=512M

[Install]
WantedBy=multi-user.target
